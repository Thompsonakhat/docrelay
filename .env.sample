# Telegram
TELEGRAM_BOT_TOKEN=

# MongoDB for persistence and long-term memory
MONGODB_URI=

# CookMyBots AI Gateway base URL and key
# Example endpoint: https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_ENDPOINT=
COOKMYBOTS_AI_KEY=

# Admin Telegram user IDs, comma-separated
ADMIN_USER_IDS=

# Optional support/admin chat notification target
SUPPORT_CHAT_ID=

# Runtime tuning
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20
CONFIDENCE_THRESHOLD=0.55
MAX_CONTEXT_TURNS=12
MEMORY_LOG_INTERVAL_MS=60000
DOCS_STORAGE_DIR=./data/docs
